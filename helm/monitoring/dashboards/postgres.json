{
  "title": "PostgreSQL Metrics",
  "uid": "postgres-metrics",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "id": 4,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "pg_stat_activity_count{datname=\"mydb\"}",
        "legendFormat": "{{state}}",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": {} }
    },
    {
      "id": 2,
      "title": "Transactions per second",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=\"mydb\"}[1m])", "legendFormat": "Commits/s", "datasource": "Prometheus" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=\"mydb\"}[1m])", "legendFormat": "Rollbacks/s", "datasource": "Prometheus" }
      ],
      "fieldConfig": { "defaults": {} }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "pg_stat_database_blks_hit{datname=\"mydb\"} / (pg_stat_database_blks_hit{datname=\"mydb\"} + pg_stat_database_blks_read{datname=\"mydb\"}) * 100",
        "legendFormat": "Cache hit %",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
  "id": 1,
  "title": "PostgreSQL Status",
  "type": "stat",
  "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
  "targets": [{
    "expr": "pg_up",
    "legendFormat": "DB Status",
    "datasource": "Prometheus"
  }],
  "fieldConfig": {
    "defaults": {
      "mappings": [
        { "type": "value", "options": { "0": { "text": "0 — DOWN", "color": "red" } } },
        { "type": "value", "options": { "1": { "text": "1 — UP", "color": "green" } } }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "red", "value": 0 },
          { "color": "green", "value": 1 }
        ]
      },
      "color": { "mode": "thresholds" }
    }
  },
  "options": {
    "reduceOptions": { "calcs": ["lastNotNull"] },
    "orientation": "auto",
    "textMode": "auto",
    "colorMode": "background"
  }
}
  ]
}